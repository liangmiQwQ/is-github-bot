{
  "name": "is-github-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run website#dev",
    "build": "vp run -r build",
    "release": "bumpp --commit \"chore: release v%s\" --tag \"v%s\" --push"
  },
  "devDependencies": {
    "bumpp": "catalog:cli",
    "vite-plus": "catalog:build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.2.2"
}
