{
  "name": "is-github-bot",
  "version": "0.0.0",
  "description": "Detect AI issue and pull request spammers on GitHub.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangmiQwQ/is-github-bot.git",
    "directory": "packages/is-github-bot"
  },
  "bin": {
    "is-github-bot": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
