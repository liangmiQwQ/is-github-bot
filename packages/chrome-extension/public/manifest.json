{
  "manifest_version": 3,
  "name": "Is GitHub Bot",
  "version": "0.0.0",
  "description": "Detect AI issue and pull request spammers on GitHub.",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
